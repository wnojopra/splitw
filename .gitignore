# pyenv
#   For a library or package, you might want to ignore these files since the code is
#   intended to run in multiple environments; otherwise, check them in:
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if delegates have different python versions passed
#   to Pipfile, they should ignore it:
#Pipfile.lock

# poetry
#   Similar to Pipenv, poetry.lock is generally recommended to be committed
#Poetry.lock

# pdm
#   Similar to Pipenv, pdm.lock is generally recommended to be committed
#pdm.lock
#   pdm build stage
.pdm-build/

# PEP 582; replacement of a virtualenv
__pypackages__/

